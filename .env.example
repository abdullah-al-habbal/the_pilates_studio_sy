# APP SETTINGS FOR PILATES STUDIO BACKEND PROJECT
APP_NAME="Pilates Studio Backend Project"
APP_ENV=local
APP_KEY=base64:lhP764kJDcNKyikrpEZxGUnH75kjdyNK+164riG57GQ=
APP_DEBUG=true
APP_URL=http://localhost

# locale
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# maintenance
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# php cli server
# PHP_CLI_SERVER_WORKERS=4

# bcrypt
BCRYPT_ROUNDS=12

# logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pilates_studio_backend_dev_db
DB_USERNAME=root
DB_PASSWORD=2072001

# session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# broadcasting
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# cache
CACHE_STORE=database
# CACHE_PREFIX=

# memcached
MEMCACHED_HOST=127.0.0.1

# redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# mail
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# aws
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# vite
VITE_APP_NAME="${APP_NAME}"

# firebase configuration, note: put the correct path to your firebase credentials json file, and the .env path must start from the app
FIREBASE_CREDENTIALS=app/firebase/firebase-credentials.json
FIREBASE_PROJECT_ID=pilates-studio-backend-dev
FIREBASE_DATABASE_URL=https://pilates-studio-backend-dev.firebaseio.com

# Filament panel configuration
FILAMENT_PATH=admin
FILAMENT_DOMAIN=
# Enable SPA mode (true|false)
FILAMENT_SPA=true
# Enable SPA prefetching when SPA mode is enabled (true|false)
FILAMENT_SPA_PREFETCH=true
# Enable strict authorization (true|false)
FILAMENT_STRICT_AUTH=false

# Filament error notification customization
FILAMENT_ERROR_NOTIFICATION_TITLE="An error occurred"
FILAMENT_ERROR_NOTIFICATION_BODY="Please try again later."
FILAMENT_ERROR_NOTIFICATION_404_TITLE="Not found"
FILAMENT_ERROR_NOTIFICATION_404_BODY="The requested resource was not found."

